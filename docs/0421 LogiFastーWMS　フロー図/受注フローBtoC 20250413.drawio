          <mxGeometry x="-676" y="638" width="50" height="30" as="geometry" />
        </mxCell>
        <mxCell id="EsIEiZSqzr4dMlcNRezW-37" value="&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;有缺货的情况下&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;・在画面上显示&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;・输出缺货 CSV&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="-531" y="489" width="104" height="55" as="geometry" />
        </mxCell>
        <mxCell id="EsIEiZSqzr4dMlcNRezW-38" value="&lt;div&gt;欠货示例&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;全部缺货：订单中的所有商品都缺货 → 该订单进入“缺货状态”&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;部分缺货：订单中只有部分商品缺货 → 该订单进入“保留状态”&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;CSV 上传时不会自动登记缺货信息 → 存在差异，需要确认&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;多个订单同时进行分配引当时出现缺货的情况&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;只有缺货的订单不会被引当&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;有库存的订单会正常登记&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;例：&lt;/span&gt;&lt;/div&gt;&lt;div&gt;引当订单 A、B、C 时，仅订单 B 缺货 →&lt;/div&gt;&lt;div&gt;订单 A、C 正常登记，B 不进行引当&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="-469" y="653" width="345" height="156" as="geometry" />
        </mxCell>
        <mxCell id="EsIEiZSqzr4dMlcNRezW-39" value="&lt;div&gt;缺货、保留状态&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・保存 7 天，之后自动删除&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・第 6 天发送提醒通知&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・在画面上清晰显示存在“缺货／保留中的订单”&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・对于保留状态的订单，其已分配的商品会进行库存预留&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・若订单被删除，则解除对应的库存预留&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="-401" y="519" width="318" height="98" as="geometry" />
        </mxCell>
        <mxCell id="EsIEiZSqzr4dMlcNRezW-40" value="&lt;div&gt;汇总定义（订单合并）&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;将尚未“订单确定”的多个订单数据合并为一个订单（订单同梱）&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;判定条件：以下 4 项全部一致时可合并&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;配送地址&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;配送联系电话&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;配送邮编&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;收件人姓名&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;此外，该功能为可选项（Option）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;是否作为&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;合并对象&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;不合并对象&lt;/span&gt;&lt;/div&gt;&lt;div&gt;由客户主档进行管理&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="-1149" y="680" width="350" height="213" as="geometry" />
        </mxCell>
        <mxCell id="EsIEiZSqzr4dMlcNRezW-41" value="&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;取消功能&lt;/span&gt;&lt;br data-start=&quot;4&quot; data-end=&quot;7&quot; style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;编辑功能&lt;/span&gt;&lt;br data-start=&quot;11&quot; data-end=&quot;14&quot; style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;;&quot;&gt;搜索功能&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="-611" y="969" width="66" height="55" as="geometry" />
        </mxCell>
        <mxCell id="EsIEiZSqzr4dMlcNRezW-42" value="&lt;div&gt;&lt;div&gt;订单合并示例（例 1）&lt;/div&gt;&lt;div&gt;条件：配送先全部一致 → 可以合并为 1 个运单号码&lt;/div&gt;&lt;div&gt;消费者 A&lt;/div&gt;&lt;div&gt;订单编号&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;下单时间&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;商品&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;配送地&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;→&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;合并后订单编号&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;母订单编号&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;商品&lt;/div&gt;&lt;div&gt;001&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;11点&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;苹果 1 个&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;东京&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;→&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;001&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;003&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;苹果 2 个（合并后）→ 1 个运单号码&lt;/div&gt;&lt;div&gt;001&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;11点&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;香蕉 1 个&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;东京&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;→&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;002&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&#x9;&lt;/span&gt;香蕉 1 个&lt;/div&gt;&lt;div&gt;002&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;12点&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;苹果 1 个&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;东京&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&#x9;&#x9;&#x9;&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;订单合并示例（例 2）&lt;/div&gt;&lt;div&gt;条件：配送地不完全一致 → 无法全部合并 → 会产生 2 个运单号码&lt;/div&gt;&lt;div&gt;消费者 A&lt;/div&gt;&lt;div&gt;订单编号&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;下单时间&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;商品&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;配送地&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;→&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;合并后订单编号&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;母订单编号&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;商品&lt;/div&gt;&lt;div&gt;001&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;11点&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;苹果 1 个&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;东京&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;→&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;001&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;003&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;苹果 1 个&lt;/div&gt;&lt;div&gt;001&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;11点&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;香蕉 1 个&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;千叶&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;→&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;002&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;003&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;香蕉 1 个 → 因地址不同，产生 2 个运单号码&lt;/div&gt;&lt;div&gt;002&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;12点&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;香蕉 1 个&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;东京&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;→&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;001&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&#x9;&lt;/span&gt;香蕉 1 个&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="-1059" y="1358" width="880" height="270" as="geometry" />
        </mxCell>
        <mxCell id="EsIEiZSqzr4dMlcNRezW-43" value="　顧客&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;　　　LogiFast&lt;div style=&quot;&quot;&gt;受注番号&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;受注&lt;/span&gt;管理&lt;span style=&quot;white-space: pre;&quot;&gt;番号&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;　NO&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;YES&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;　YES&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;YES&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fillColor=default;strokeColor=default;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="-301" y="28" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="EsIEiZSqzr4dMlcNRezW-44" value="自動処理（部分例&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;）&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・メール送信&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・ステータス移動&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;新規注文→発送待ち&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;発送待ち→単品SKU&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・配送日及びお届け時間帯指定&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;など&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;" vertex="1" parent="1">
