        <mxCell id="ci5UeUbU_JjLxQW9Pvxf-78" value="〇" style="connectable=0;recursiveResize=0;strokeColor=inherit;fillColor=none;align=center;whiteSpace=wrap;html=1;" vertex="1" parent="ci5UeUbU_JjLxQW9Pvxf-73">
