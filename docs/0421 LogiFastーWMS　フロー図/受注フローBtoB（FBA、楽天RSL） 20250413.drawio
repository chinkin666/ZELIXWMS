        </mxCell>
        <mxCell id="fGoumwFbU-MffXeTV5u5-33" value="&lt;p&gt;有缺货的情况下&lt;br&gt;・在画面上显示&lt;br&gt;・输出缺货 CSV&lt;/p&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=0;fontFamily=Times New Roman;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="-650" y="468" width="110" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fGoumwFbU-MffXeTV5u5-34" value="&lt;h1 data-start=&quot;51&quot; data-end=&quot;69&quot;&gt;&lt;span data-start=&quot;53&quot; data-end=&quot;69&quot; style=&quot;font-weight: normal;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;欠货处理示例&lt;/font&gt;&lt;/span&gt;&lt;/h1&gt;&lt;ul data-start=&quot;71&quot; data-end=&quot;190&quot;&gt;&lt;li data-start=&quot;71&quot; data-end=&quot;109&quot;&gt;&lt;p data-start=&quot;73&quot; data-end=&quot;109&quot;&gt;&lt;font&gt;&lt;strong data-start=&quot;73&quot; data-end=&quot;81&quot;&gt;全部缺货&lt;/strong&gt;：订单内的所有商品都缺货 → 该订单进入“缺货状态”&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;110&quot; data-end=&quot;148&quot;&gt;&lt;p data-start=&quot;112&quot; data-end=&quot;148&quot;&gt;&lt;font&gt;&lt;strong data-start=&quot;112&quot; data-end=&quot;120&quot;&gt;部分缺货&lt;/strong&gt;：订单内只有部分商品缺货 → 该订单进入“保留状态”&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;149&quot; data-end=&quot;190&quot;&gt;&lt;p data-start=&quot;151&quot; data-end=&quot;190&quot;&gt;&lt;font&gt;&lt;strong data-start=&quot;151&quot; data-end=&quot;176&quot;&gt;通过 CSV 上传时，不会自动登记缺货信息&lt;/strong&gt; → 存在差异，需要确认&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2 data-start=&quot;197&quot; data-end=&quot;222&quot;&gt;&lt;strong data-start=&quot;200&quot; data-end=&quot;222&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;多个订单同时进行分配引当时的缺货逻辑&lt;/font&gt;&lt;/strong&gt;&lt;/h2&gt;&lt;p data-start=&quot;224&quot; data-end=&quot;245&quot;&gt;&lt;font&gt;当对多个订单进行引当，并且出现缺货时：&lt;/font&gt;&lt;/p&gt;&lt;ul data-start=&quot;246&quot; data-end=&quot;280&quot;&gt;&lt;li data-start=&quot;246&quot; data-end=&quot;264&quot;&gt;&lt;p data-start=&quot;248&quot; data-end=&quot;264&quot;&gt;&lt;font&gt;只有“缺货的订单”不会被引当&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;265&quot; data-end=&quot;280&quot;&gt;&lt;p data-start=&quot;267&quot; data-end=&quot;280&quot;&gt;&lt;font&gt;有库存的订单会正常登记&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p data-start=&quot;282&quot; data-end=&quot;364&quot;&gt;&lt;font&gt;&lt;strong data-start=&quot;282&quot; data-end=&quot;288&quot;&gt;例：&lt;/strong&gt;&lt;br data-start=&quot;288&quot; data-end=&quot;291&quot;&gt;&lt;br&gt;对 A、B、C 订单进行分配引当，只有订单 B 缺货时：&lt;br data-start=&quot;319&quot; data-end=&quot;322&quot;&gt;&lt;br&gt;→ 订单 A、订单 C 正常登记&lt;br data-start=&quot;338&quot; data-end=&quot;341&quot;&gt;&lt;br&gt;→ 订单 B 不进行引当（进入缺货或保留状态）&lt;/font&gt;&lt;/p&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=0;fontFamily=Times New Roman;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="-584" y="640" width="420" height="390" as="geometry" />
        </mxCell>
        <mxCell id="fGoumwFbU-MffXeTV5u5-35" value="&lt;p&gt;缺货、保留状态&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;保留 7 天，之后自动删除&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;第 6 天发出提醒通知&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;在画面上以醒目的方式显示存在“缺货・保留中的订单”&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;对于处于保留状态的订单，已分配的商品要进行库存预留&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;若该订单被删除，则解除相应的库存预留&lt;/p&gt;&lt;br&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=0;fontFamily=Times New Roman;fontSize=12;" vertex="1" parent="1">
