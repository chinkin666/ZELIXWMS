        <mxCell id="NkKqWxzrblvbB4j_6Jyp-143" value="&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;西濃運輸を利用時のみ&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;・OneByOneで対応&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;・重量により、運賃が変更するため&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
