# ============================================================
# ZELIX WMS Backend — 环境变量 / 環境変数
# ============================================================
# 复制此文件为 .env 并填入实际值 / このファイルを .env にコピーして実際の値を入力
# cp .env.example .env
# ============================================================

# Core service / コアサービス
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:4001
CORS_ORIGINS=http://localhost:4001,http://localhost:3000,http://localhost:3001,http://localhost:3002

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/nexand-shipment
MONGODB_DB=nexand-shipment

# Redis (BullMQ queue — optional, auto-fallback if unavailable)
# Redis (BullMQ キュー — オプション、利用不可時は自動降級)
REDIS_URL=redis://127.0.0.1:6379

# File storage / ファイルストレージ
FILE_STORAGE_BUCKET=local
FILE_STORAGE_DIR=./tmp/uploads
# For S3: FILE_STORAGE_BUCKET=s3, AWS_ACCESS_KEY_ID=..., AWS_SECRET_ACCESS_KEY=..., AWS_REGION=..., AWS_S3_BUCKET=...

# Auth — MUST change in production! / 本番環境では必ず変更してください！
SESSION_SECRET=replace-me-in-production
JWT_SECRET=replace-me-in-production

# MongoDB 接続プール / 连接池
# MONGODB_POOL_SIZE=10

# JWT 有効期限 / JWT有效期
# JWT_EXPIRES_IN=24h

# ログレベル / 日志级别 (debug | info | warn | error)
# LOG_LEVEL=info

# External services / 外部サービス
YAMATO_CALC_BASE_URL=https://yamato-calc.nexand.org
