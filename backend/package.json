{
  "name": "nexand-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Nexand 出荷管理システム backend services",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --config nodemon.json",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint --ext .ts src",
    "lint:fix": "eslint --ext .ts src --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\" && prettier --write \"docs/**/*.md\"",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "seed:b2-mapping": "ts-node -r tsconfig-paths/register src/scripts/seedB2Mapping.ts",
    "db:clear": "ts-node -r tsconfig-paths/register src/scripts/clearDb.ts",
    "db:dump": "ts-node -r tsconfig-paths/register src/scripts/dumpDb.ts",
    "db:restore": "ts-node -r tsconfig-paths/register src/scripts/restoreDb.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "bullmq": "^5.71.0",
    "bwip-js": "^4.8.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "graphql": "^16.13.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "muhammara": "^6.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.2",
    "pdf-lib": "^1.17.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "piscina": "^5.1.4",
    "sharp": "^0.34.5",
    "skia-canvas": "^3.0.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bwip-js": "^3.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.13",
    "@types/nodemailer": "^7.0.11",
    "@types/sharp": "^0.31.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
