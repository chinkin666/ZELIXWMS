# =============================================================================
# ZELIXWMS 生产环境变量配置模板
# ZELIXWMS 本番環境変数設定テンプレート
#
# 使用方法: 复制此文件为 .env.production 并填入实际值
# 使用方法: このファイルを .env.production にコピーして実際の値を入力
# =============================================================================

# -----------------------------------------------------------------------------
# 运行环境 / 実行環境
# 必须设为 production / production に設定必須
# -----------------------------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------------------------
# 服务端口 / サービスポート
# 后端 API 监听端口 / バックエンド API リスニングポート
# -----------------------------------------------------------------------------
PORT=4000

# -----------------------------------------------------------------------------
# MongoDB 连接地址 / MongoDB 接続URI
# [必填] 生产环境数据库连接字符串
# [必須] 本番環境データベース接続文字列
# 示例 / 例: mongodb+srv://user:password@cluster.mongodb.net/zelixwms?retryWrites=true&w=majority
# -----------------------------------------------------------------------------
MONGODB_URI=

# -----------------------------------------------------------------------------
# Redis 连接地址 / Redis 接続URL
# [必填] 用于缓存和会话存储
# [必須] キャッシュとセッションストレージに使用
# 示例 / 例: redis://username:password@host:6379
# -----------------------------------------------------------------------------
REDIS_URL=

# -----------------------------------------------------------------------------
# JWT 密钥 / JWT シークレット
# [必填] 用于签发和验证 JWT 令牌
# [必須] JWT トークンの発行と検証に使用
# ⚠️  必须修改为强随机字符串，不可使用默认值！
# ⚠️  強力なランダム文字列に変更必須、デフォルト値使用禁止！
# 生成方法 / 生成方法: openssl rand -base64 64
# -----------------------------------------------------------------------------
JWT_SECRET=

# -----------------------------------------------------------------------------
# 会话密钥 / セッションシークレット
# [必填] 用于 Express 会话加密
# [必須] Express セッション暗号化に使用
# ⚠️  必须修改为强随机字符串
# ⚠️  強力なランダム文字列に変更必須
# 生成方法 / 生成方法: openssl rand -base64 64
# -----------------------------------------------------------------------------
SESSION_SECRET=

# -----------------------------------------------------------------------------
# CORS 允许的来源 / CORS 許可オリジン
# 前端应用的URL（多个用逗号分隔）
# フロントエンドアプリのURL（複数はカンマ区切り）
# 示例 / 例: https://app.zelixwms.com,https://admin.zelixwms.com
# -----------------------------------------------------------------------------
CORS_ORIGINS=

# -----------------------------------------------------------------------------
# JWT 有效期 / JWT 有効期限
# 令牌的有效时间 / トークンの有効時間
# 示例 / 例: 1h, 2h, 1d, 7d
# -----------------------------------------------------------------------------
JWT_EXPIRES_IN=1d
