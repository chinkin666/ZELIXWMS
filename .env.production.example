# ============================================================
# ZELIXWMS Production Environment Variables
# 本番環境変数 / 生产环境变量
# ============================================================
# Copy this file to .env.production and fill in values
# このファイルを .env.production にコピーして値を設定してください
# ============================================================

# ── Node.js ──
NODE_ENV=production

# ── PostgreSQL ──
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Supabase Auth (optional — dev mode uses local DB auth) ──
# Supabase 認証（任意 — 開発モードはローカルDB認証）
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── JWT ──
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING

# ── Yamato B2 Cloud API プロキシ / 大和B2 Cloud API代理 ──
# Docker Compose内ではb2-proxyサービス名を使用 / Docker Compose内使用服务名
B2_API_URL=http://b2-proxy:8000
B2_API_KEY=
B2_JWT_SECRET=CHANGE_ME_B2_SECRET
B2_FERNET_KEY=

# ── SSL/HTTPS (future) ──
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
