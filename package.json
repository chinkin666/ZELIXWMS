{
  "name": "zelixwms",
  "version": "1.0.0",
  "private": true,
  "description": "ZELIX WMS — 出荷管理システム / 出货管理系统",
  "workspaces": [
    "backend-nest",
    "frontend",
    "admin",
    "portal"
  ],
  "scripts": {
    "dev": "cd backend-nest && npm run start:dev",
    "build": "cd backend-nest && npm run build",
    "test": "cd backend-nest && npx jest --passWithNoTests",
    "typecheck": "cd backend-nest && npx tsc --noEmit",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:admin": "cd admin && npm run dev",
    "dev:portal": "cd portal && npm run dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:rebuild": "docker compose up -d --build",
    "db:migrate": "cd backend-nest && npx drizzle-kit migrate",
    "db:generate": "cd backend-nest && npx drizzle-kit generate",
    "prod:check": "bash scripts/prod-check.sh"
  },
  "dependencies": {}
}
