{
  "name": "nexand-shipment-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Nexand 出荷管理システム",
  "workspaces": [
    "backend",
    "frontend",
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run bootstrap --workspaces --if-present",
    "lint": "npm run lint --workspace backend",
    "db": "mongod --dbpath ./local-db/mongo",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:prod": "npm run dev:prod --workspace frontend",
    "seed": "npm run seed --workspace backend",
    "db:dump": "npm run db:dump --workspace backend",
    "db:restore": "npm run db:restore --workspace backend"
  }
}




